generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("agent")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedProjects Project[] @relation("AssignedAgent")
  activities       Activity[]
  customPages      CustomPage[]

  @@index([role])
}

model Client {
  id               String    @id @default(cuid())
  name             String
  whatsappNumber   String    @unique
  email            String?
  businessType     String?
  location         String?
  servicesUsed     String[]
  totalSpent       Int       @default(0)
  firstProjectDate DateTime?
  lastProjectDate  DateTime?
  status           String    @default("active")
  referralSource   String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  projects  Project[]
  payments  Payment[]
  retainers Retainer[]
  messages  Message[]
  referrals Referral[]
  appointments Appointment[]

  @@index([status])
  @@index([referralSource])
  @@index([totalSpent])
  @@index([createdAt])
}

model Project {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  serviceType     String
  description     String?
  quotedAmount    Int
  depositAmount   Int?
  status          String        @default("new_inquiry")
  priority        String?
  assignedAgentId String?
  assignedAgent   User?         @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  quotedAt        DateTime?
  depositPaidAt   DateTime?
  startedAt       DateTime?
  v1DeliveredAt   DateTime?
  finalDeliveredAt DateTime?
  paidAt          DateTime?

  revisionsUsed   Int           @default(0)
  maxRevisions    Int           @default(2)
  rushFee         Int           @default(0)

  driveFolderUrl  String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  payments        Payment[]
  messages        Message[]
  steps           PipelineStep[]
  appointments    Appointment[]
  checkups        ProjectCheckup[]

  @@index([clientId])
  @@index([status])
  @@index([assignedAgentId])
  @@index([serviceType])
  @@index([priority])
  @@index([createdAt])
}

model Payment {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  amount         Int
  usdEquiv       Int?
  method         String   @default("mpesa")
  status         String   @default("unpaid")

  mpesaReference String?
  receiptUrl     String?
  balanceDue     Int?

  notes          String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([method])
  @@index([paidAt])
  @@index([createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Int
  receipt     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}

model Retainer {
  id                String   @id @default(cuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  package           String   @default("custom")
  monthlyValue      Int
  contentDueBy      DateTime
  status            String   @default("active")

  currentMonth      String?
  graphicsDue       Int      @default(12)
  graphicsDelivered Int      @default(0)

  paymentStatus     String   @default("unpaid")
  lastPaymentDate   DateTime?
  nextPaymentDate   DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([clientId, currentMonth])
  @@index([nextPaymentDate])
  @@index([paymentStatus])
}

model Message {
  id                 String   @id @default(cuid())
  direction          String   @default("incoming")
  channel            String   @default("whatsapp")
  content            String
  mediaUrl           String?

  clientId           String
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId             String?

  evolutionMessageId String?  @unique
  chatwootMessageId  String?  @unique

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([userId])
  @@index([channel])
  @@index([direction])
  @@index([createdAt])
}

model Activity {
  id         String       @id @default(cuid())
  type       String
  actorId    String?
  actorName  String?

  targetType String
  targetId   String

  meta       Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([type])
  @@index([createdAt])
}

model Appointment {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  allDay      Boolean  @default(false)

  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  color       String?
  status      String   @default("scheduled")

  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([startTime])
  @@index([status])
}

model Integration {
  id           String   @id @default(cuid())
  name         String   @unique
  status       String   @default("disconnected")
  lastSyncAt   DateTime?
  config       Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model QuickReply {
  id        String   @id @default(cuid())
  shortcut  String   @unique
  title     String
  content   String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String
  eventType String
  payload   Json
  status    String   @default("received")
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([createdAt])
  @@index([status])
}

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  description String?

  trigger     String   @default("message_received")
  conditions  Json     @default("[]")
  actions     Json     @default("[]")

  isActive    Boolean  @default(true)
  runCount    Int      @default(0)
  lastRunAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trigger])
  @@index([isActive])
}

// ── Spec Feature Models ──────────────────────────────────────────────

model ServicePricing {
  id          String   @id @default(cuid())
  name        String
  category    String
  floorTsh    Int
  ceilingTsh  Int
  floorUsd    Int?
  ceilingUsd  Int?
  estimatedHr Float?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model PipelineStep {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  step        String
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, step])
}

model IncomeLog {
  id            String   @id @default(cuid())
  weekStart     DateTime
  amountTsh     Int
  amountUsd     Int?
  clientCount   Int      @default(0)
  retainerCount Int      @default(0)
  paidClients   Int      @default(0)
  unpaidAmount  Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([weekStart])
}

model WedgeLog {
  id          String   @id @default(cuid())
  problem     String
  description String?
  clientCount Int      @default(1)
  frequency   String?
  potential   String?
  notes       String?
  isProduct   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientCount])
  @@index([potential])
}

model LearningProgress {
  id          String    @id @default(cuid())
  track       String
  phase       String?
  taskName    String
  completedAt DateTime?
  streak      Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([track])
  @@index([completedAt])
}

model ContentCalendar {
  id           String   @id @default(cuid())
  platform     String
  pillar       String?
  contentText  String?
  mediaUrl     String?
  caption      String?
  hashtags     String?
  scheduledFor DateTime
  postedAt     DateTime?
  status       String   @default("draft")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platform])
  @@index([scheduledFor])
  @@index([status])
}

model GrowthMilestone {
  id           String   @id @default(cuid())
  period       String
  title        String
  targetIncome String?
  items        String[]
  isComplete   Boolean  @default(false)
  completedAt  DateTime?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([period])
}

// ── v7 Command Center Models ──────────────────────────────────────────

model ArabicSession {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  type      String   @default("duo")
  duration  Int      @default(15)
  notes     String?
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type])
}

model Grade {
  id         String @id @default(cuid())
  courseCode String
  courseName String
  instructor String?
  assignment Float? @default(0)
  midterm    Float? @default(0)
  exam       Float? @default(0)
  total      Float? @default(0)
  targetExam Float?
  semester   String @default("2025/2026")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([courseCode, semester])
  @@index([semester])
}

model Habit {
  id        String    @id @default(cuid())
  name      String
  icon      String    @default("✅")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  logs HabitLog[]

  @@index([isActive])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
  @@index([date])
}

model TimerSession {
  id        String   @id @default(cuid())
  mode      String   @default("focus")
  duration  Int      @default(25)
  taskLabel String?
  phase     String?
  completed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([phase])
}

model JournalEntry {
  id        String   @id @default(cuid())
  category  String   @default("daily")
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}

model Book {
  id         String   @id @default(cuid())
  title      String
  author     String?
  pages      Int      @default(0)
  status     String   @default("unread")
  rating     Int?
  notes      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions ReadingSession[]

  @@index([status])
}

model ReadingSession {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pagesRead Int      @default(1)
  date      DateTime @default(now())
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
  @@index([date])
}

model Goal {
  id          String  @id @default(cuid())
  level       String
  title       String
  description String?
  parentId    String?
  parent      Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Goal[]  @relation("GoalHierarchy")
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([level])
  @@index([parentId])
}

model Idea {
  id              String   @id @default(cuid())
  problem         String
  solution        String?
  targetUser      String?
  validationNotes String?
  status          String   @default("idea")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  company       String?
  role          String?
  notes         String?
  platform      String?
  profileUrl    String?
  lastContacted DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, platform])
  @@index([company])
  @@index([platform])
}

model Commitment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([completed])
  @@index([dueDate])
}

model SaasIdea {
  id        String   @id @default(cuid())
  name      String
  description String?
  market    String?
  techStack String?
  status    String   @default("idea")
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model WeeklyReview {
  id           String   @id @default(cuid())
  weekStart    DateTime
  wins         String?
  lessons      String?
  priorities   String?
  energy       Int?
  focus        Int?
  habitPercent Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([weekStart])
}

model PortfolioProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("idea")
  url         String?
  techStack   String?
  startedAt   DateTime?
  launchedAt  DateTime?
  income      Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model SkillRating {
  id        String   @id @default(cuid())
  name      String   @unique
  rating    Int      @default(5)
  category  String?
  tier      Int?
  gap       String?
  resources String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([tier])
}

model TrajectoryMilestone {
  id        String   @id @default(cuid())
  year      String
  label     String
  target    String?
  income    String?
  isCurrent Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
}

model Movie {
  id       String   @id @default(cuid())
  key      String   @unique
  title    String
  year     Int
  saga     String?
  phase    String?
  watched  Boolean  @default(false)
  withMary Boolean  @default(false)
  rewatch  Boolean  @default(false)
  category String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([saga])
  @@index([watched])
}

model UserConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ProjectCheckup {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase      String    @default("general")
  question   String
  answer     String?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  answeredAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([phase])
}

model WhatsAppSync {
  id            String    @id @default(cuid())
  state         String    @default("disconnected")
  messagesToday Int       @default(0)
  messagesTotal Int       @default(0)
  lastMessageAt DateTime?
  qr            String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([state])
  @@index([createdAt])
}

model Reminder {
  id        String   @id @default(cuid())
  title     String
  context   String?
  priority  String   @default("medium")
  dueAt     DateTime?
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dismissed])
  @@index([priority])
  @@index([dueAt])
}

model CustomPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  config    Json
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([updatedAt])
}

// ── Business Spec v2 Models ───────────────────────────────────────────

model RoutineSlot {
  id        String   @id @default(cuid())
  time      String
  label     String
  duration  Int
  dayOfWeek Int?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs RoutineLog[]

  @@index([dayOfWeek])
  @@index([isActive])
}

model RoutineLog {
  id             String      @id @default(cuid())
  slotId         String
  slot           RoutineSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  date           DateTime    @default(now())
  completed      Boolean     @default(false)
  durationActual Int?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([slotId, date])
}

model SocialMediaPost {
  id           String   @id @default(cuid())
  platform     String
  pillar       String
  contentType  String   @default("feed")
  title        String?
  contentUrl   String?
  status       String   @default("draft")
  scheduledFor DateTime?
  postedAt     DateTime?
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  saves        Int      @default(0)
  shares       Int      @default(0)
  dmsReceived  Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platform])
  @@index([pillar])
  @@index([contentType])
  @@index([status])
  @@index([scheduledFor])
  @@index([postedAt])
}

model SocialMediaCollab {
  id                String   @id @default(cuid())
  partnerName       String
  partnerHandle     String?
  platform          String
  followerCount     Int?
  offer             String
  deliverables      String?
  postedAt          DateTime?
  accepted          Boolean  @default(false)
  convertedToClient Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([platform])
  @@index([accepted])
  @@index([convertedToClient])
}

model ChecklistItem {
  id          String                @id @default(cuid())
  category    String
  title       String
  description String?
  isRequired  Boolean               @default(true)
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  completions ChecklistCompletion[]

  @@index([category])
}

model ChecklistCompletion {
  id          String        @id @default(cuid())
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  completedAt DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([itemId, completedAt])
  @@index([itemId])
}

model Referral {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  referredName  String?
  referredPhone String?
  status        String   @default("asked")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, referredPhone])
  @@index([clientId])
  @@index([status])
}

model ProductTransition {
  id        String   @id @default(cuid())
  stage     String
  startedAt DateTime @default(now())
  isCurrent Boolean  @default(true)
  metrics   Json?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([isCurrent])
  @@index([startedAt])
}
