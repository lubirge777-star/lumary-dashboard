# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/lumi_crm

# Auth (generate a strong random string: openssl rand -base64 32)
AUTH_SECRET=your-random-secret-here-at-least-32-chars

# NextAuth
NEXTAUTH_URL=http://localhost:3000

# Optional: MCP API key to protect the /api/v1/mcp endpoint
# MCP_API_KEY=your-mcp-api-key

# Optional: Direct database URL for Prisma migrations (not pooled)
# DIRECT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/lumi_crm
